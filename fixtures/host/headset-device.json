{
  "$schema": "rusty.manifold.host.manifest.v1",
  "host_id": "host.headset_device",
  "authority_role": "observer",
  "host_category": "headset.device",
  "clock_domain": "clock.host_monotonic",
  "endpoints": [
    {
      "endpoint_id": "endpoint.headset_loopback",
      "visibility": "loopback",
      "transport": "http",
      "security": "local_process"
    }
  ],
  "capabilities": [
    "manifold.graph.read",
    "manifold.command.request",
    "manifold.package.inspect",
    "manifold.module.control",
    "manifold.graph.run"
  ],
  "supported_backends": [
    "backend.synthetic",
    "backend.replay",
    "backend.headset_device"
  ],
  "permissions": [
    "permission.app_lifecycle",
    "permission.operator_pairing"
  ],
  "lifecycle_limits": [
    "lifecycle.foreground_sensitive",
    "lifecycle.immersive_session_bound"
  ],
  "missing_requirements": []
}
