{
  "$schema": "rusty.manifold.host.manifest.v1",
  "host_id": "host.synthetic",
  "authority_role": "primary",
  "host_category": "host.synthetic",
  "clock_domain": "clock.host_monotonic",
  "endpoints": [
    {
      "endpoint_id": "endpoint.control_loopback",
      "visibility": "loopback",
      "transport": "http",
      "security": "local_process"
    }
  ],
  "capabilities": [
    "manifold.graph.read",
    "manifold.command.request",
    "manifold.module.control",
    "manifold.graph.run",
    "manifold.stream_registry.update",
    "manifold.host_manifest.update",
    "manifold.clock.update"
  ],
  "supported_backends": [
    "backend.synthetic",
    "backend.replay"
  ],
  "permissions": [],
  "lifecycle_limits": [],
  "missing_requirements": []
}
