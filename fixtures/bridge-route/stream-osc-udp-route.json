{
  "$schema": "rusty.manifold.bridge.route_descriptor.v1",
  "route_id": "bridge_route.stream.osc.udp",
  "route_kind": "stream_bridge",
  "plane": "telemetry",
  "transport_family": "osc",
  "delivery": "best_effort",
  "payload_class": "stream_packet",
  "rate_class": "periodic",
  "authority_role": "adapter",
  "required_evidence_stages": [
    "sent",
    "transport_ok",
    "observed"
  ],
  "fallback_route_ids": [
    "bridge_route.stream.websocket.ordered"
  ],
  "issue_codes": [
    "issue.bridge_route.packet_loss",
    "issue.bridge_route.decode_error",
    "issue.bridge_route.clock_uncorrelated"
  ],
  "required_conditions": [
    {
      "condition_id": "condition.network.same_lan_reachable",
      "scope": "network",
      "kind": "same_lan_reachable",
      "required_state": "reachable",
      "check_ref": "check.network.same_lan_reachable",
      "issue_codes": [
        "issue.network.not_reachable"
      ],
      "remediation": {
        "action_ref": "remediation.network.join_same_lan",
        "operator_label": "Put the host and headset on the same reachable LAN"
      }
    },
    {
      "condition_id": "condition.host.osc_udp_firewall_inbound",
      "scope": "security",
      "kind": "host_firewall_inbound_allowed",
      "required_state": "allowed",
      "check_ref": "check.host.firewall.osc_udp_inbound",
      "issue_codes": [
        "issue.host.firewall_blocked"
      ],
      "remediation": {
        "action_ref": "remediation.host.allow_osc_udp_port",
        "operator_label": "Allow the OSC UDP port through Windows Firewall"
      }
    },
    {
      "condition_id": "condition.runtime.osc_consumer_active",
      "scope": "runtime",
      "kind": "runtime_subscriber_active",
      "required_state": "active",
      "check_ref": "check.runtime.osc_consumer_active",
      "issue_codes": [
        "issue.runtime.subscriber_missing"
      ],
      "remediation": {
        "action_ref": "remediation.runtime.start_osc_consumer",
        "operator_label": "Start the OSC stream consumer"
      }
    },
    {
      "condition_id": "condition.clock.lsl_parallel_route",
      "scope": "protocol",
      "kind": "clock_reference_route_available",
      "required_state": "available",
      "check_ref": "check.clock.lsl_parallel_route",
      "issue_codes": [
        "issue.bridge_route.clock_uncorrelated"
      ],
      "remediation": {
        "action_ref": "remediation.clock.start_lsl_echo",
        "operator_label": "Start the LSL clock echo route for timing alignment"
      }
    }
  ],
  "timing": {
    "rtt_strategy": "parallel_lsl_clock_echo",
    "clock_domain": "clock.host_monotonic",
    "parallel_clock_route_id": "bridge_route.clock.lsl.roundtrip_echo",
    "min_round_trips": 8,
    "timeout_ms": 5000,
    "warmup_ms": 250,
    "reported_metrics": [
      "rtt_ms",
      "one_way_estimate_ms",
      "clock_offset_ms",
      "jitter_ms",
      "sample_loss"
    ]
  }
}
