{
  "$schema": "rusty.manifold.bridge.route_descriptor.v1",
  "route_id": "bridge_route.stream.zeromq.pub_sub",
  "route_kind": "stream_bridge",
  "plane": "data",
  "transport_family": "zeromq",
  "delivery": "best_effort",
  "payload_class": "stream_packet",
  "rate_class": "periodic",
  "authority_role": "adapter",
  "required_evidence_stages": [
    "sent",
    "transport_ok",
    "observed"
  ],
  "fallback_route_ids": [
    "bridge_route.stream.websocket.ordered"
  ],
  "issue_codes": [
    "issue.bridge_route.packet_loss",
    "issue.bridge_route.decode_error",
    "issue.bridge_route.queue_overflow"
  ],
  "required_conditions": [
    {
      "condition_id": "condition.tooling.zeromq.library",
      "scope": "tooling",
      "kind": "protocol_library_available",
      "required_state": "available",
      "check_ref": "check.tooling.zeromq.library",
      "issue_codes": [
        "issue.tooling.protocol_library_missing"
      ],
      "remediation": {
        "action_ref": "remediation.tooling.enable_zeromq_adapter",
        "operator_label": "Install or enable the ZeroMQ adapter runtime"
      }
    },
    {
      "condition_id": "condition.network.zeromq_tcp_endpoint",
      "scope": "network",
      "kind": "tcp_endpoint_reachable",
      "required_state": "reachable",
      "check_ref": "check.network.zeromq_tcp_endpoint",
      "issue_codes": [
        "issue.network.not_reachable"
      ],
      "remediation": {
        "action_ref": "remediation.network.open_zeromq_endpoint",
        "operator_label": "Bind or connect the declared ZeroMQ TCP endpoint"
      }
    },
    {
      "condition_id": "condition.clock.lsl_parallel_route",
      "scope": "protocol",
      "kind": "clock_reference_route_available",
      "required_state": "available",
      "check_ref": "check.clock.lsl_parallel_route",
      "issue_codes": [
        "issue.bridge_route.clock_uncorrelated"
      ],
      "remediation": {
        "action_ref": "remediation.clock.start_lsl_echo",
        "operator_label": "Start the LSL clock echo route for timing alignment"
      }
    }
  ],
  "timing": {
    "rtt_strategy": "parallel_lsl_clock_echo",
    "clock_domain": "clock.host_monotonic",
    "parallel_clock_route_id": "bridge_route.clock.lsl.roundtrip_echo",
    "min_round_trips": 8,
    "timeout_ms": 5000,
    "warmup_ms": 250,
    "reported_metrics": [
      "rtt_ms",
      "one_way_estimate_ms",
      "clock_offset_ms",
      "jitter_ms",
      "sample_loss",
      "queue_delay_ms"
    ]
  },
  "zeromq": {
    "socket_pattern": "pub_sub",
    "endpoint_open_mode": "connect",
    "endpoint_url": "tcp://127.0.0.1:5570",
    "topic_prefix": "rusty.manifold.qcl084",
    "payload_encoding": "json",
    "max_message_bytes": 4096,
    "high_water_mark": 16,
    "queue_policy": "drop_oldest"
  }
}
