{
  "$schema": "rusty.manifold.bridge.route_descriptor.v1",
  "route_id": "bridge_route.clock.lsl.roundtrip_echo",
  "route_kind": "stream_bridge",
  "plane": "telemetry",
  "transport_family": "lsl",
  "delivery": "ordered",
  "payload_class": "stream_packet",
  "rate_class": "event",
  "authority_role": "adapter",
  "required_evidence_stages": [
    "sent",
    "transport_ok",
    "observed"
  ],
  "fallback_route_ids": [],
  "issue_codes": [
    "issue.bridge_route.lsl_native_unavailable",
    "issue.bridge_route.clock_uncorrelated",
    "issue.bridge_route.sample_loss",
    "issue.bridge_route.discovery_timeout"
  ],
  "required_conditions": [
    {
      "condition_id": "condition.tooling.lsl.native_library",
      "scope": "tooling",
      "kind": "native_library_available",
      "required_state": "available",
      "check_ref": "check.tooling.lsl.native_library",
      "issue_codes": [
        "issue.bridge_route.lsl_native_unavailable"
      ],
      "remediation": {
        "action_ref": "remediation.tooling.install_lsl_runtime",
        "operator_label": "Install or package the LSL native runtime"
      }
    },
    {
      "condition_id": "condition.network.multicast_allowed",
      "scope": "network",
      "kind": "multicast_allowed",
      "required_state": "allowed",
      "check_ref": "check.network.lsl_multicast",
      "issue_codes": [
        "issue.network.multicast_blocked"
      ],
      "remediation": {
        "action_ref": "remediation.network.allow_lsl_multicast",
        "operator_label": "Use a LAN profile that permits LSL multicast discovery"
      }
    },
    {
      "condition_id": "condition.runtime.lsl_echo_subscriber",
      "scope": "runtime",
      "kind": "runtime_subscriber_active",
      "required_state": "active",
      "check_ref": "check.runtime.lsl_echo_subscriber",
      "issue_codes": [
        "issue.runtime.subscriber_missing"
      ],
      "remediation": {
        "action_ref": "remediation.runtime.start_lsl_echo",
        "operator_label": "Start the runtime LSL echo subscriber"
      }
    }
  ],
  "timing": {
    "rtt_strategy": "native_round_trip",
    "clock_domain": "clock.lsl_local",
    "min_round_trips": 8,
    "timeout_ms": 5000,
    "warmup_ms": 250,
    "reported_metrics": [
      "rtt_ms",
      "clock_offset_ms",
      "clock_uncertainty_ms",
      "jitter_ms",
      "sample_loss"
    ]
  },
  "lsl": {
    "stream_name": "ClockEcho",
    "stream_type": "rusty.manifold.clock.echo",
    "source_id": "rusty.manifold.clock.echo.source",
    "endpoint_role": "round_trip",
    "resolve_policy": "name_and_type",
    "channel_count": 1,
    "channel_format": "string",
    "channel_labels": [
      "clock_alignment_echo"
    ],
    "sample_rate_policy": "irregular",
    "clock_policy": "round_trip_offset",
    "resolve_timeout_ms": 5000,
    "sample_timeout_ms": 2000,
    "warmup_ms": 250,
    "min_samples": 8
  }
}
