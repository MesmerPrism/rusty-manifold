{
  "$schema": "rusty.manifold.bridge.route_descriptor.v1",
  "route_id": "bridge_route.device.adb.transport_only",
  "route_kind": "device_management",
  "plane": "control",
  "transport_family": "adb",
  "delivery": "transport_acknowledged",
  "payload_class": "device_command",
  "rate_class": "on_demand",
  "authority_role": "adapter",
  "required_evidence_stages": [
    "sent",
    "transport_ok"
  ],
  "fallback_route_ids": [
    "bridge_route.device.platform_tooling.transport_only"
  ],
  "issue_codes": [
    "issue.bridge_route.device_missing",
    "issue.bridge_route.transport_failed"
  ],
  "required_conditions": [
    {
      "condition_id": "condition.device.adb_online",
      "scope": "device",
      "kind": "adb_device_online",
      "required_state": "active",
      "check_ref": "check.device.adb_online",
      "issue_codes": [
        "issue.bridge_route.device_missing"
      ],
      "remediation": {
        "action_ref": "remediation.device.connect_adb",
        "operator_label": "Connect and authorize the headset over ADB"
      }
    },
    {
      "condition_id": "condition.network.adb_forward_active",
      "scope": "network",
      "kind": "adb_forward_active",
      "required_state": "active",
      "check_ref": "check.network.adb_forward_active",
      "issue_codes": [
        "issue.bridge_route.transport_failed"
      ],
      "remediation": {
        "action_ref": "remediation.network.create_adb_forward",
        "operator_label": "Create the required ADB forward or reverse tunnel"
      }
    }
  ],
  "timing": {
    "rtt_strategy": "transport_echo",
    "clock_domain": "clock.host_monotonic",
    "min_round_trips": 1,
    "timeout_ms": 5000,
    "warmup_ms": 0,
    "reported_metrics": [
      "rtt_ms",
      "jitter_ms"
    ]
  }
}
